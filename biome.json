{
	"$schema": "https://biomejs.dev/schemas/1.8.3/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "main"
	},
	"organizeImports": {
		"enabled": true
	},
	"formatter": {
		"enabled": true,
		"lineWidth": 120,
		"ignore": [".next/*", "node_modules"]
	},
	"files": {
		"ignore": [".next/*", "src/gql/**/*", "node_modules"]
	},
	"linter": {
		"ignore": [
			".next/*",
			"src/graphql/typeSlut.js",
			"src/components/MDX/sugar.js",
			"src/components/MDX/vidID.js",
			"src/components/MDX/Lite.mjs"
		],
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noBannedTypes": "off"
			},
			"a11y": {
				"useButtonType": "off",
				"noSvgWithoutTitle": "off",
				"useKeyWithClickEvents": "off"
			},
			"correctness": {
				"noChildrenProp": "off",
				"useExhaustiveDependencies": "warn"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"noImplicitAnyLet": "off",
				"noArrayIndexKey": "off"
			},
			"style": {
				"useConst": "off",
				"noUnusedTemplateLiteral": "off",
				"noNonNullAssertion": "off"
			}
		}
	}
}
