datasource db {
  provider = "postgresql"
  url      = env("SUPABASE_PG_URL")
}

generator client {
  provider         = "prisma-client-js"
  precountFeatures = ["filteredRelationCount"]
  relationMode     = "foreignKeys"
}

model Account {
  id                String  @id @default(dbgenerated("(concat('acc_', xid()))::TEXT"))
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(dbgenerated("(concat('sss_', xid()))::TEXT"))
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id        String   @id @default(dbgenerated("(concat('usr_', xid()))::TEXT"))
  createdAt DateTime @default(now())

  name  String
  image String?
  email String? @unique

  role    Role    @default(USER)
  isAdmin Boolean @default(false)

  emailVerified DateTime?
  pendingEmail  String?
  description   String?    @db.VarChar(256)
  location      String?    @db.VarChar(32)
  twitterId     String?    @unique
  accounts      Account[]
  sessions      Session[]
  comments      Comment[]
  questions     Question[]
  reactions     Reaction[]
  posts         Post[]
  stacks        Stack[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  BLOCKED
  USER
  ADMIN
}

model Bookmark {
  id            String     @id @default(dbgenerated("(concat('bkm_', xid()))::TEXT"))
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  url           String     @unique
  host          String?
  title         String?
  image         String?
  description   String?
  twitterHandle String?
  faviconUrl    String?
  comments      Comment[]
  reactions     Reaction[]
  tags          Tag[]

  @@index([host])
}

model Question {
  id          String     @id @default(dbgenerated("(concat('qst_', xid()))::TEXT"))
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  author      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  plays       Int        @default(0)
  waveform    Json?
  audioUrl    String?
  description String?
  userId      String
  comments    Comment[]
  reactions   Reaction[]

  @@index([userId])
}

model Comment {
  id        String   @id @default(dbgenerated("(concat('cmt_', xid()))::TEXT"))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  text       String
  audio      Audio?
  author     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  bookmark   Bookmark? @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)
  question   Question? @relation(fields: [questionId], references: [id], onDelete: Cascade)
  post       Post?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  stack      Stack?    @relation(fields: [stackId], references: [id], onDelete: Cascade)
  bookmarkId String?
  questionId String?
  postId     String?
  stackId    String?

  @@index([bookmarkId])
  @@index([questionId])
  @@index([postId])
  @@index([stackId])
  @@index([userId])
}

model Audio {
  id            String   @id @default(dbgenerated("(concat('aud_', xid()))::TEXT"))
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  plays         Int
  waveform      Json
  url           String
  transcription String
  comment       Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId     String   @unique
}

model Post {
  id           String     @id @default(dbgenerated("(concat('pos_', xid()))::TEXT"))
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  publishedAt  DateTime?
  author       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug         String     @unique
  title        String
  text         String
  excerpt      String
  featureImage String?
  comments     Comment[]
  reactions    Reaction[]
  history      PostEdit[]
  userId       String

  @@index([publishedAt])
  @@index([userId])
}

model PostEdit {
  id           String   @id @default(dbgenerated("(concat('ped_', xid()))::TEXT"))
  createdAt    DateTime @default(now())
  text         String
  title        String
  excerpt      String
  featureImage String?
  post         Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId       String?

  @@index([postId])
}

model Tag {
  id        String     @id @default(dbgenerated("(concat('tag_', xid()))::TEXT"))
  name      String     @unique
  stacks    Stack[]
  bookmarks Bookmark[]
}

model Stack {
  id          String     @id @default(dbgenerated("(concat('stk_', xid()))::TEXT"))
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  name        String
  slug        String?    @unique
  description String
  image       String
  url         String
  tags        Tag[]
  comments    Comment[]
  reactions   Reaction[]
  users       User[]
}

model Reaction {
  id        String   @id @default(dbgenerated("(concat('rct_', xid()))::TEXT"))
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  bookmark   Bookmark? @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)
  question   Question? @relation(fields: [questionId], references: [id], onDelete: Cascade)
  post       Post?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  stack      Stack?    @relation(fields: [stackId], references: [id], onDelete: Cascade)
  bookmarkId String?
  questionId String?
  postId     String?
  stackId    String?

  @@index([bookmarkId])
  @@index([questionId])
  @@index([postId])
  @@index([stackId])
  @@index([userId])
}

model PageView {
  id        String   @id @default(dbgenerated("(concat('pgv_', xid()))::TEXT"))
  lastSeen  DateTime @default(now())
  slug      String   @unique
  viewCount BigInt   @default(1)
}

model Sticker {
  id        String   @id @default(dbgenerated("(concat('stc_', xid()))::TEXT"))
  createdAt DateTime @default(now())
  model     String   @unique
  label     String
  url       String
  metadata  Json?
}

enum EmailSubscriptionType {
  HACKER_NEWS
}

model EmailSubscription {
  email String
  type  EmailSubscriptionType

  @@unique(fields: [email, type], name: "emailAndType")
  @@index([email])
}
