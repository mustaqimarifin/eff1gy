    "@graphql-codegen/typescript": "^2.8.1",
    "@graphql-codegen/typescript-operations": "^2.5.6",
    "@graphql-codegen/typescript-react-apollo": "^3.3.6",
    "@next/eslint-plugin-next": "^12.3.3",
    "@types/dom-mediacapture-record": "^1.0.13",
