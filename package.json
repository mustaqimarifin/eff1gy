{
  "name": "eff1gy",
  "version": "1.0.0",
  "scripts": {
    "dev": "next",
    "build": "next build",
    "start": "next start",
    "format": "pnpm prettier --write . --ignore-path .gitignore",
    "lint": "next lint -- --ignore-path .gitignore",
    "lint:fix": "pnpm format && pnpm lint -- --fix",
    "generate": "graphql-codegen",
    "generate:watch": "graphql-codegen --watch 'src/graphql/**/*.ts'",
    "prod:db:seed": "dotenv -- sh -c 'SUPABASE_URL=\"$MIGRATE_DATABASE_URL\" prisma db seed'",
    "postinstall": "pnpm generate && prisma generate"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "dependencies": {
    "@apollo/client": "^3.7.1",
    "@apollo/server": "^4.1.1",
    "@as-integrations/next": "^1.2.0",
    "@auth0/nextjs-auth0": "^1.9.2",
    "@graphql-tools/schema": "^9.0.10",
    "@headlessui/react": "^1.7.4",
    "@prisma/client": "^4.6.1",
    "@tailwindcss/forms": "^0.5.3",
    "@tailwindcss/line-clamp": "^0.4.2",
    "@tailwindcss/typography": "^0.5.8",
    "@tanstack/react-query": "^4.16.1",
    "@tippyjs/react": "^4.2.6",
    "cheerio": "^1.0.0-rc.10",
    "cloudinary": "^1.32.0",
    "deepmerge": "^4.2.2",
    "feed": "^4.2.2",
    "framer-motion": "^7.6.9",
    "graphql": "^16.6.0",
    "graphql-type-json": "^0.3.2",
    "jsonwebtoken": "^8.5.1",
    "lodash": "^4.17.21",
    "lru-cache": "^6.0.0",
    "next": "^13.0.5",
    "next-seo": "^5.14.1",
    "next-themes": "^0.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "14.2.3",
    "react-feather": "^2.0.10",
    "react-hot-toast": "^2.1.1",
    "react-linkify": "^1.0.0-alpha",
    "react-markdown": "^8.0.3",
    "react-syntax-highlighter": "^15.4.5",
    "react-textarea-autosize": "^8.4.0",
    "react-visibility-sensor": "^5.1.1",
    "rehype-autolink-headings": "^6.1.1",
    "rehype-parse": "^8.0.3",
    "rehype-raw": "^6.1.1",
    "rehype-remark": "^9.1.2",
    "rehype-sanitize": "^5.0.1",
    "rehype-slug": "^5.0.1",
    "rehype-stringify": "^9.0.2",
    "remark": "^14.0.2",
    "remark-gfm": "^3.0.1",
    "remark-linkify-regex": "^1.1.0",
    "remark-preset-lint-recommended": "^6.1.2",
    "remark-rehype": "^10.1.0",
    "remove-markdown": "^0.3.0",
    "slugify": "^1.6.4",
    "string-replace-to-array": "^2.1.0",
    "turndown": "^7.1.1",
    "turndown-plugin-gfm": "^1.0.2",
    "unified": "^10.1.1",
    "unified-stream": "^2.0.0",
    "xid-js": "^1.0.1"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^4.1.3",
    "@graphql-codegen/add": "^3.2.1",
    "@graphql-codegen/cli": "^2.14.1",
    "@graphql-codegen/typescript": "^2.8.2",
    "@graphql-codegen/typescript-operations": "^2.5.7",
    "@graphql-codegen/typescript-react-apollo": "^3.3.6",
    "@next/eslint-plugin-next": "^13.0.4",
    "@types/chai": "^4.3.0",
    "@types/dom-mediacapture-record": "^1.0.10",
    "@types/mocha": "^9.0.0",
    "@types/node": "^18.11.9",
    "@types/react": "^18.0.25",
    "@types/webrtc": "^0.0.31",
    "@typescript-eslint/eslint-plugin": "^5.44.0",
    "@typescript-eslint/parser": "^5.44.0",
    "autoprefixer": "^10.4.13",
    "eslint": "^8.28.0",
    "eslint-config-next": "^13.0.4",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-mdx": "^1.16.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.31.11",
    "eslint-plugin-simple-import-sort": "^8.0.0",
    "husky": "^7.0.4",
    "lint-staged": "^12.1.7",
    "postcss": "^8.4.19",
    "postcss-import": "^14.0.2",
    "postcss-preset-env": "^7.2.0",
    "prettier": "^2.5.1",
    "prettier-eslint": "^13.0.0",
    "prettier-plugin-prisma": "^4.4.0",
    "prisma": "^4.6.1",
    "stylelint-config-recommended": "^6.0.0",
    "tailwindcss": "^3.2.4",
    "typescript": "^4.9.3"
  },
  "lint-staged": {
    "*.+(ts|tsx)": [
      "eslint --fix",
      "prettier --write --ignore-unknown"
    ]
  },
  "pre-commit": "lint:staged && generate",
  "license": "MIT"
}
