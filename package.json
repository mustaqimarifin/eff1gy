    "cheerio": "^1.0.0-rc.12",
    "cloudinary": "^1.32.0",
    "cryptr": "^6.0.3",
    "date-fns": "^2.29.3",
    "deepmerge": "^4.2.2",
    "feed": "^4.2.2",
    "framer-motion": "^6.5.1",
    "graphql": "^15.8.0",
    "isomorphic-unfetch": "^3.1.0",
    "jsonwebtoken": "^8.5.1",
    "lodash": "^4.17.21",
    "lru-cache": "^6.0.0",
    "next": "12.3.3",
    "next-seo": "^4.29.0",
    "next-themes": "^0.2.1",
    "postmark": "^2.9.5",
