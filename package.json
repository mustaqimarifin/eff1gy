{
  "name": "eff1gy",
  "version": "1.0.7",
  "scripts": {
    "dev": "next",
    "build": " next build",
    "start": "next start",
    "format": "pnpm dlx prettier --write . --ignore-path .gitignore",
    "lint": "next lint -- --ignore-path .gitignore",
    "lint:fix": "pnpm format && pnpm lint -- --fix",
    "generate": "graphql-codegen",
    "generate:watch": "graphql-codegen --watch 'src/graphql/**/*.ts'",
    "prod:db:seed": "dotenv -- sh -c 'SUPABASE_URL=\"$MIGRATE_DATABASE_URL\" prisma db seed'",
    "postinstall": "pnpm generate && prisma generate"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "dependencies": {
    "@apollo/client": "^3.7.2",
    "@apollo/server": "^4.3.0",
    "@as-integrations/next": "^1.2.0",
    "@code-hike/mdx": "^0.7.4",
    "@graphql-tools/schema": "^9.0.12",
    "@headlessui/react": "1.7.5",
    "@next-auth/prisma-adapter": "^1.0.5",
    "@prisma/client": "^4.7.1",
    "@radix-ui/react-dropdown-menu": "^2.0.1",
    "@tanstack/react-query": "^4.19.1",
    "@vercel/analytics": "^0.1.6",
    "cheerio": "1.0.0-rc.12",
    "cloudinary": "^1.32.0",
    "clsx": "^1.2.1",
    "deepmerge": "^4.2.2",
    "esbuild": "^0.16.7",
    "feed": "^4.2.2",
    "framer-motion": "^7.8.0",
    "graphql": "^16.6.0",
    "graphql-type-json": "^0.3.2",
    "jsonwebtoken": "^8.5.1",
    "lodash": "^4.17.21",
    "mdx-bundler": "^9.0.1",
    "next": "^13.0.6",
    "next-auth": "^4.18.6",
    "next-seo": "^5.15.0",
    "next-themes": "^0.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "14.2.3",
    "react-feather": "^2.0.10",
    "react-hot-toast": "^2.4.0",
    "react-markdown": "^8.0.4",
    "react-responsive": "^9.0.2",
    "react-textarea-autosize": "^8.4.0",
    "react-visibility-sensor": "^5.1.1",
    "rehype-autolink-headings": "^6.1.1",
    "rehype-preset-minify": "^6.0.0",
    "rehype-pretty-code": "^0.5.1",
    "rehype-sanitize": "^5.0.1",
    "rehype-slug": "^5.1.0",
    "remark": "^14.0.2",
    "remark-gfm": "^3.0.1",
    "remark-linkify-regex": "^1.2.1",
    "remark-preset-lint-recommended": "^6.1.2",
    "remove-markdown": "^0.5.0",
    "sharp": "^0.31.2",
    "shiki": "^0.11.1",
    "swr": "^2.0.0",
    "xid-js": "^1.0.1"
  },
  "devDependencies": {
    "@graphql-codegen/add": "^3.2.3",
    "@graphql-codegen/cli": "^2.16.1",
    "@graphql-codegen/named-operations-object": "^2.3.1",
    "@graphql-codegen/typescript": "^2.8.5",
    "@graphql-codegen/typescript-apollo-client-helpers": "^2.2.6",
    "@graphql-codegen/typescript-operations": "^2.5.10",
    "@graphql-codegen/typescript-react-apollo": "^3.3.7",
    "@next/eslint-plugin-next": "^13.0.6",
    "@radix-ui/react-icons": "^1.1.1",
    "@tailwindcss/forms": "^0.5.3",
    "@tailwindcss/line-clamp": "^0.4.2",
    "@tailwindcss/typography": "^0.5.8",
    "@types/dom-mediacapture-record": "^1.0.14",
    "@types/lodash": "^4.14.191",
    "@types/node": "^18.11.15",
    "@types/react": "^18.0.26",
    "@types/webrtc": "^0.0.33",
    "@typescript-eslint/eslint-plugin": "^5.46.1",
    "@typescript-eslint/parser": "^5.46.1",
    "autoprefixer": "^10.4.13",
    "compression-webpack-plugin": "^10.0.0",
    "critters": "^0.0.16",
    "cssnano": "^5.1.14",
    "dotenv-cli": "^6.0.0",
    "eslint": "^8.29.0",
    "eslint-config-next": "^13.0.6",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-mdx": "^2.0.5",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.31.11",
    "eslint-plugin-simple-import-sort": "^8.0.0",
    "husky": "^8.0.2",
    "lint-staged": "^13.1.0",
    "postcss": "^8.4.20",
    "postcss-preset-env": "^7.8.3",
    "prettier": "^2.8.1",
    "prettier-eslint": "^15.0.1",
    "prettier-plugin-prisma": "^4.4.0",
    "prisma": "^4.7.1",
    "stylelint-config-recommended": "^9.0.0",
    "tailwindcss": "^3.2.4",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.4"
  },
  "lint-staged": {
    "*.+(ts|tsx)": [
      "eslint --fix",
      "prettier --write --ignore-unknown"
    ]
  },
  "pre-commit": "lint:staged && generate",
  "license": "MIT"
}
